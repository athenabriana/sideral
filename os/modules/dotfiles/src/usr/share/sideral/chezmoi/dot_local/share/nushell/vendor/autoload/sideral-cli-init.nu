# ~/.local/share/nushell/vendor/autoload/sideral-cli-init.nu
#
# Managed by chezmoi (source: dot_local/share/nushell/vendor/autoload/
# sideral-cli-init.nu). Edit freely after first apply — chezmoi will only
# re-apply if you run `chezmoi apply`. Run `ujust apply-defaults` to
# restore the sideral default.
#
# Loaded automatically from $nu.vendor-autoload-dirs at every nushell
# session. Runs in env-phase — only env-safe constructs here.
#
# Per-tool prompt/history/jump inits (starship, atuin, zoxide, mise) are
# pre-generated by chezmoi's run_onchange_after_install-nu-prompts.sh
# into sibling files in this same dir. Nushell auto-sources every .nu
# file here, so we don't `source` them ourselves — nushell's `source`
# is a parse-time keyword and the cmd-pipe-save-source pattern fails on
# cold shells; the apply-time pre-generation sidesteps that entirely.
#
# Carapace external completer + Ctrl-P keybinding are config-phase and
# live in ~/.config/nushell/config.nu.

# ── Default editor split ────────────────────────────────────────────────
if (which hx | is-not-empty) {
    $env.EDITOR = "hx"
}
if (which code | is-not-empty) {
    $env.VISUAL = "code"
}

# ── ls shorthands ───────────────────────────────────────────────────────
# Bash/zsh muscle memory shortcuts. Both wrap nu's built-in `ls`
# (structured table) — no eza, no GNU coreutils, no aliasing of `ls`
# itself. The structured output is the whole point of nu for pipelines
# and agent use; these are just typing conveniences.
#
# `ll`   — long+all (`ls -la`) trimmed to the 5 columns a bash user
#          reaches for: name, type (d/f/symlink), mode, size, modified.
#          The full 13-column `ls -la` output is one keystroke away.
# `la`   — list all incl. dotfiles, default short-form columns
#          (name, type, size, modified). No mode/permissions — use
#          `ll` if you want long+all.
# `tree` — recursive view via eza (icons + tree-drawing chars), default
#          depth 5 + --git-ignore so node_modules / target / .venv /
#          dist / etc. don't flood the output inside a git repo (the
#          flag is a no-op outside one). Override depth with
#          `tree -L 10 path/` or `tree --level=10 path/` — eza takes
#          the last --level flag. To include gitignored files, bypass
#          this wrapper: `^eza --icons --tree --level=5 path/`. Shadows
#          the system `tree` binary in nu — call `^tree` for the GNU
#          one. Falls through to `^eza` (external command) so structured-
#          data piping is intentionally not provided here.
def --wrapped ll [...args] { ls -la ...$args | select name type mode size modified }
def --wrapped la [...args] { ls -a ...$args }
def --wrapped tree [...args] { ^eza --icons --tree --level=5 --git-ignore ...$args }
