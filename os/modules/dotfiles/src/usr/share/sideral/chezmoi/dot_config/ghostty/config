# sideral default ghostty config — mirrors niri keybinds but with Alt
# instead of Super so the muscle memory carries over inside the terminal.
# tabs are ghostty's analog to niri columns; splits are the in-tab analog
# to multi-window-per-column.
#
# Theme is sourced from Noctalia's matugen pipeline at
# `~/.config/ghostty/config.ghostty` (overwritten on every wallpaper change).

config-file = ?config.ghostty

# --- tabs (mirror niri columns: Mod+H/L → Alt+H/L) ---
keybind = alt+t=new_tab
keybind = alt+q=close_surface
keybind = alt+h=previous_tab
keybind = alt+l=next_tab
keybind = alt+left=previous_tab
keybind = alt+right=next_tab
keybind = alt+shift+h=move_tab:-1
keybind = alt+shift+l=move_tab:1
keybind = alt+shift+left=move_tab:-1
keybind = alt+shift+right=move_tab:1

# --- numbered tab focus (mirror niri workspaces 1–9) ---
keybind = alt+one=goto_tab:1
keybind = alt+two=goto_tab:2
keybind = alt+three=goto_tab:3
keybind = alt+four=goto_tab:4
keybind = alt+five=goto_tab:5
keybind = alt+six=goto_tab:6
keybind = alt+seven=goto_tab:7
keybind = alt+eight=goto_tab:8
keybind = alt+nine=goto_tab:9

# --- splits (mirror niri windows-within-column: Mod+J/K → Alt+J/K) ---
keybind = alt+d=new_split:right
keybind = alt+shift+d=new_split:down
keybind = alt+j=goto_split:bottom
keybind = alt+k=goto_split:top
keybind = alt+down=goto_split:bottom
keybind = alt+up=goto_split:top

# --- launcher analog: Alt+Space → command palette (mirror Mod+Space) ---
keybind = alt+space=toggle_command_palette
