# sideral — a personal Fedora atomic desktop derived directly from
# ublue-os/silverblue-main. Ships GNOME + tiling-shell, Zen Browser
# (preinstalled Flatpak from Flathub), a curated flatpak set (GNOME
# quality-of-life apps, preinstalled at image build), chezmoi-driven
# user dotfile layer + sideral-cli-tools (mise, code, starship, atuin,
# fzf, etc.), and a narrow RPM layer (rootless podman with docker
# compatibility shims, gnome extensions + gnome-software, fonts).
#
# Local build:    just build
# Local rebase:   just rebase
# CI build:       push to main → GH Actions → ghcr.io/<user>/sideral:latest
# Remote rebase:  rpm-ostree rebase ostree-unverified-registry:ghcr.io/<user>/sideral:latest
#
# Module layout:
#   os/modules/<name>/ — RPM modules; each has rpm/<spec>+src/ tree plus
#     optional packages.txt + *.sh for build-time package install/scripts.
#   os/build/<name>/   — build-time-only (no RPM); just packages.txt + *.sh.
#     Currently: fonts/ (Fedora + Adobe fonts), nvidia/ (variant overlay).
# The orchestrator (os/lib/build.sh) processes both directories.
# The inline rpmbuild step (os/lib/build-rpms.sh) walks os/modules/ only.
#
# rpmbuild + rpm -Uvh + rpm -e of the toolchain happen in one RUN layer
# so no rpmbuild artifacts bloat the final image. RPMs exist only inside
# the image — there is no Copr project, no external repo, no token.
# The image rebuild IS the upgrade.

ARG BASE_IMAGE="ghcr.io/ublue-os/silverblue-main:44"

# Stage 1: scratch carrier for build scripts + module sources — bind-
# mounted, never embedded in final image.
FROM scratch AS ctx
COPY lib /lib
COPY modules /modules
COPY build /build

# Stage 2: the real image.
FROM ${BASE_IMAGE}

# Inherits build-time arg used by lib/build-rpms.sh to stamp version.
# CI overrides via --build-arg SIDERAL_VERSION=YYYYMMDD.<run>; local builds
# default to 0.0.0.dev (sentinel for "this didn't come from CI").
ARG SIDERAL_VERSION=0.0.0.dev

RUN --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/lib/build.sh && \
    ostree container commit

# Build sideral-* RPMs inline, install them, remove the build toolchain.
# Single RUN layer = no rpmbuild scratch in the final image. RPMs exist only
# inside this image.
#
# Several sideral files conflict with base-image packages on file
# ownership (/etc/os-release vs fedora-release-common,
# /etc/containers/policy.json vs containers-common, /etc/zshrc vs zsh).
# rpm -Uvh --replacefiles transfers ownership cleanly — the standard
# derivative-distro pattern. dnf install rejects file conflicts.
# (The /etc/yum.repos.d/docker-ce.repo conflict went away 2026-05-02
# when the docker stack was swapped for rootless podman.)
#
# `rpm -e --nodeps ublue-os-signing` runs first: silverblue-main:44 ships
# ublue-os-signing pre-installed, and sideral-base declares Conflicts:
# against it (both own /etc/containers/policy.json). rpm -Uvh refuses
# package-level Conflicts even with --replacefiles, so we remove the
# predecessor explicitly. --nodeps is safe here because nothing else in
# the base image Requires ublue-os-signing.
#
# Requires: podman-docker / podman-compose / podman must already be
# installed (build.sh above did that via the containers module plus
# silverblue-main's preinstalled podman); rpm -Uvh verifies presence
# but won't fetch.
#
# `rpm -e` (not `dnf remove`) for the toolchain teardown: dnf would
# auto-remove ~73 transitively-pulled packages (cpio, diffutils, elfutils,
# file, …), several of which are part of the silverblue base. rpm -e
# removes only the two packages we asked for; the now-orphaned deps stay
# put. Net image size impact is near zero on silverblue-main where those
# packages were already present.
RUN --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=tmpfs,dst=/tmp \
    dnf5 install -y rpm-build rpmdevtools && \
    /ctx/lib/build-rpms.sh /ctx/modules /tmp/rpmbuild "${SIDERAL_VERSION}" && \
    rpm -e --nodeps ublue-os-signing && \
    rpm -Uvh --replacefiles --replacepkgs /tmp/rpmbuild/RPMS/noarch/sideral-*.rpm && \
    rpm -e rpm-build rpmdevtools && \
    rm -rf /tmp/rpmbuild && \
    ostree container commit

# Final bootc sanity check.
RUN bootc container lint
