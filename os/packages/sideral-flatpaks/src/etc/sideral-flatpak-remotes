# sideral curated flatpak remotes. Read by os/build.sh at image build
# (to register + preinstall the curated set into /var/lib/flatpak) and
# by sideral-flatpak-install.service on every boot (idempotent re-add,
# so deployed systems pick up new remotes added in future image rebases).
# Format:
#   <name>  <url-or-flatpakrepo>
# Lines starting with # and blank lines are ignored.

# Flathub — primary community flatpak distribution.
flathub  https://dl.flathub.org/repo/flathub.flatpakrepo

# Fedora Flatpak registry (Fedora-built, signed flatpaks).
fedora   oci+https://registry.fedoraproject.org

# Helium browser — community-packaged Helium (MarioGK/helium-flatpak).
# Real ostree archive-z2 remote served from GitHub Pages with a CI-driven
# build pipeline. GPGVerify=false; trust = TLS + single-maintainer
# community repo. (ShyVortex/helium-flatpak ships .flatpak bundles via
# Releases only; no ostree remote.)
helium   https://mariogk.github.io/helium-flatpak/helium.flatpakrepo
