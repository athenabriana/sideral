# Flatpaks preinstalled at image build by os/build.sh and self-healed on
# every boot by sideral-flatpak-install.service.
# Format:
#   <remote> <ref>           — install <ref> from named remote
# Lines starting with # and blank lines are ignored.

# ── Browser ──
# Helium is community-packaged via ShyVortex/helium-flatpak (no Flathub
# listing, no upstream flatpak). The `helium` remote is registered by
# os/build.sh from https://shyvortex.github.io/helium-flatpak/.
helium net.imput.helium

# ── GNOME quality-of-life ──
flathub com.github.tchx84.Flatseal
flathub io.github.flattool.Warehouse
flathub com.mattjakeman.ExtensionManager
flathub io.podman_desktop.PodmanDesktop
flathub com.ranfdev.DistroShelf
flathub net.nokyan.Resources
flathub it.mijorus.smile
