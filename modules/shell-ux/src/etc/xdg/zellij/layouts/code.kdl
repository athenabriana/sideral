// `code` layout — sideral IDE-style three-tab session.
//
// Tab `editor`: fullscreen helix in $PWD (`<space>f` for file picker)
// Tab `git`:    fullscreen lazygit
// Tab `term`:   scratch shell — quick build/test commands
//
// Switch with Alt+1/2/3 (or Ctrl+T then 1/2/3).
//
// Launched via the `edit` wrapper:
//   cd ~/projects/foo && edit
// Re-running `edit` in the same dir reattaches to `code-foo`.

layout {
    default_tab_template {
        // Custom status bar (replaces zellij's stock mode-line).
        // wasm shipped at /etc/xdg/zellij/plugins/zjstatus.wasm.
        children
        pane size=1 borderless=true {
            plugin location="file:/etc/xdg/zellij/plugins/zjstatus.wasm" {
                format_left  "{mode} #[fg=#7aa2f7,bold]{session} {tabs}"
                format_center ""
                format_right "#[fg=#9ece6a]{command_git_branch} #[fg=#bb9af7]{datetime}"
                format_space "#[bg=default]"

                mode_normal  "#[bg=#7aa2f7,fg=#1a1b26,bold] NORMAL "
                mode_locked  "#[bg=#f7768e,fg=#1a1b26,bold] LOCKED "
                mode_resize  "#[bg=#e0af68,fg=#1a1b26,bold] RESIZE "
                mode_pane    "#[bg=#bb9af7,fg=#1a1b26,bold] PANE "
                mode_tab     "#[bg=#9ece6a,fg=#1a1b26,bold] TAB "
                mode_default_to_mode "normal"

                tab_normal   "#[fg=#7aa2f7] {name} "
                tab_active   "#[fg=#1a1b26,bg=#7aa2f7,bold] {name} "

                command_git_branch_command "git rev-parse --abbrev-ref HEAD"
                command_git_branch_format  ""
                command_git_branch_interval "10"

                datetime          "{format} "
                datetime_format   "%Y-%m-%d %H:%M"
                datetime_timezone "Etc/UTC"
            }
        }
    }

    tab name="editor" focus=true {
        pane name="editor" command="hx" {
            args "."
        }
    }

    tab name="git" {
        pane name="git" command="lazygit"
    }

    tab name="term" {
        pane
    }
}
