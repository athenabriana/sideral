# sideral default ghostty config.
#
# Modifier scheme:
#   Super → niri (compositor: column/window/workspace nav)
#   Ctrl  → ghostty (terminal: tabs/splits/palette)
#   Alt   → zellij + shell (in-pane multiplexer + readline extras)
#   bare  → helix / shell readline
#
# Ctrl bindings here will shadow some shell readline defaults inside
# ghostty (e.g. Ctrl+W normally word-deletes in bash; Ctrl+L clears
# screen; Ctrl+D sends EOF). Accepted tradeoff per the layered-modifier
# scheme — shell users reach for Backspace/`clear`/`exit` instead.

config-file = ?config.ghostty

# --- tabs ---
# Ctrl+N for new tab (frees Ctrl+T for fzf path-paste in shell)
keybind = ctrl+n=new_tab
keybind = ctrl+w=close_surface
keybind = ctrl+h=previous_tab
keybind = ctrl+l=next_tab
keybind = ctrl+left=previous_tab
keybind = ctrl+right=next_tab
keybind = ctrl+shift+h=move_tab:-1
keybind = ctrl+shift+l=move_tab:1
keybind = ctrl+shift+left=move_tab:-1
keybind = ctrl+shift+right=move_tab:1

# --- numbered tab focus ---
keybind = ctrl+one=goto_tab:1
keybind = ctrl+two=goto_tab:2
keybind = ctrl+three=goto_tab:3
keybind = ctrl+four=goto_tab:4
keybind = ctrl+five=goto_tab:5
keybind = ctrl+six=goto_tab:6
keybind = ctrl+seven=goto_tab:7
keybind = ctrl+eight=goto_tab:8
keybind = ctrl+nine=goto_tab:9

# --- splits ---
keybind = ctrl+d=new_split:right
keybind = ctrl+shift+d=new_split:down
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+down=goto_split:bottom
keybind = ctrl+up=goto_split:top

# --- command palette ---
keybind = ctrl+space=toggle_command_palette

theme = noctalia
